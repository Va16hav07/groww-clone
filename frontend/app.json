{
  "expo": {
    "name": "Groww-Clone",
    "slug": "Groww-Clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/image.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/image.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/image.png",
        "backgroundImage": "./assets/image.png",
        "monochromeImage": "./assets/image.png"
      },
      "package": "com.va16hav.GrowwClone"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "4c5b1cba-a356-44ba-ad89-937adca4640f"
      }
    }
  }
}
